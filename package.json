{
  "name": "folie-grid",
  "version": "0.2.1",
  "description": "Lightweight column grid overlay for the browser. Same columns, gutter, and margin as your Figma layout grid. Toggle it while you build.",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "dist"
  ],
  "keywords": [
    "figma",
    "grid",
    "layout",
    "overlay",
    "dev-tool",
    "columns",
    "design"
  ],
  "scripts": {
    "dev": "vite",
    "types": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/francescophra/folie.git"
  },
  "bugs": {
    "url": "https://github.com/francescophra/folie/issues"
  },
  "homepage": "https://github.com/francescophra/folie#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
